generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id         String   @id @default(cuid())
  poste      String
  entreprise String?
  annees     String[]
  logo       String?
  url        String?
  favicon    String?
  details    Json
  visible    Boolean  @default(true)
  featured   Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Education {
  id            String    @id @default(cuid())
  diplome       String
  etablissement String
  annees        String[]
  startDate     DateTime?
  endDate       DateTime?
  logo          String?
  url           String?
  details       String[]
  mention       String?
  visible       Boolean   @default(true)
  featured      Boolean   @default(false)
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Certification {
  id           String    @id @default(cuid())
  nom          String
  organisme    String
  date         DateTime
  logo         String?
  description  String?
  url          String?
  credentialId String?
  state        String    @default("ACTIVE")
  visible      Boolean   @default(true)
  featured     Boolean   @default(false)
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id                    String    @id @default(cuid())
  name                  String
  title                 String?
  description           String
  image                 String?
  image_path            String?
  technologies          String[]
  languages             Json?
  detected_technologies Json?
  html_version          String?
  modernity_score       Json?
  context               String?
  githubUrl             String?
  repo_url              String?
  liveUrl               String?
  site_url              String?
  visible               Boolean   @default(true)
  featured              Boolean   @default(false)
  challenge             String?
  strategy              String?
  tools                 String[]
  learnings             String[]
  startDate             DateTime?
  endDate               DateTime?
  order                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String
  level     Int      @default(0)
  icon      String?
  visible   Boolean  @default(true)
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SoftSkill {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  visible     Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Language {
  id        String   @id @default(cuid())
  name      String
  level     String
  flag      String?
  visible   Boolean  @default(true)
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hobby {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  visible     Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Creation {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  image       String?
  url         String?
  visible     Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Translation {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
